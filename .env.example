# LLM
GROQ_API_KEY="your_groq_api_key_here"

ZERO_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
ICHI_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
NI_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
SAN_MODEL="llama-3.3-70b-versatile"
YON_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
GO_MODEL="llama-3.3-70b-versatile"

# Tools
TAVILY_API_KEY="your_tavily_api_key_here"
JINA_API_KEYS="your_jina_api_key_here"

# Notifications
NTFY_TOPIC="senku-hokoku"     # ntfy.sh topic name
NTFY_TOKEN=""                  # ntfy auth token (optional)

DISCORD_WEBHOOK_URL=""         # Discord webhook URL (optional)

USE_NTFY=false                 # send via ntfy.sh
USE_DC=true                    # send via Discord webhook
# both false → DC fallback. both true → send both.

# Database
MONGODB_URI="your_db_uri_here"

# MCP Server ports (in-process HTTP servers)
ICHI_SERVER_PORT=8081
NI_SERVER_PORT=8082
SAN_SERVER_PORT=8083
GO_SERVER_PORT=8084

# Monitoring
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="Senku"
