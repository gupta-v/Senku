# LLM
GROQ_API_KEY=""your_groq_api_key_here""
ICHI_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
NI_MODEL="llama-3.3-70b-versatile"
SAN_MODEL="llama-3.1-8b-instant"

# Tools
TAVILY_API_KEY="your_tavily_api_key_here"
JINA_API_KEYS="your_jina_api_key_here"

# Notifications
NTFY_TOPIC="senku-hokoku" # name of server you subscribed

# Speech to Text
WHISPER_MODEL=small        # tiny/base/small/medium/large
WHISPER_DEVICE=cpu     # auto/cpu/cuda
WHISPER_COMPUTE_TYPE=int8 # auto/int8/float16

# Monitoring
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="Senku"